rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isValidSettings(settings) {
      return settings is map
        && settings.keys().hasOnly([
          'lockScreenEnabled',
          'reminderHour',
          'reminderMinute'
        ])
        && settings.keys().hasAll([
          'lockScreenEnabled',
          'reminderHour',
          'reminderMinute'
        ])
        && settings.lockScreenEnabled is bool
        && settings.reminderHour is int
        && settings.reminderHour >= 0
        && settings.reminderHour <= 23
        && settings.reminderMinute is int
        && settings.reminderMinute >= 0
        && settings.reminderMinute <= 59;
    }

    function hasValidSettings(data) {
      return !('settings' in data) || isValidSettings(data.settings);
    }

    function canUpdateOwnProfile() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'avatarUrl',
          'avatarPath',
          'settings',
          'updatedAt'
        ])
        && hasValidSettings(request.resource.data);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && hasValidSettings(request.resource.data);
      allow update: if isOwner(uid) && canUpdateOwnProfile();
      allow delete: if false;

      match /auth_logs/{logId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /my_words/{wordId} {
        allow read, write: if isOwner(uid);
      }

      match /study_events/{eventId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /sync_logs/{logId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update, delete: if false;
      }
    }

    match /topics/{topicId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /words/{wordId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }
  }
}
